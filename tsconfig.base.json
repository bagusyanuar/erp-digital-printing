{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["modules/core/src/*"],
      "@presentation/*": ["modules/presentation/src/*"],
      "@ui/*": ["packages/ui/src/components/*"],
      "@shell/*": ["apps/back-office-app/src/*"],
      "@erp-digital-printing/libs": ["packages/libs/src/index.ts"],
      "@erp-digital-printing/http": ["packages/http/src/index.ts"]
    }
  }
}
